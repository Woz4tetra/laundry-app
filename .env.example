# Copy to .env and fill in. Used by docker-compose and the server.

# Shared passcode for the app (everyone in the family types this once per device).
APP_PASSCODE=changeme

# Secret used to sign the session cookie. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Web Push (VAPID) keys for notifications. Generate with:
#   cd server && npm run gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Port the app listens on (host:container both use this via compose).
PORT=23103

# Where the SQLite database lives inside the container (mapped to ./data on the host).
DATA_DIR=/data

# Optional: local VLM endpoint for the (later) care-label scanner.
# OLLAMA_URL=http://gpu-host:11434
# OLLAMA_MODEL=qwen2.5vl:7b
